PORT=3000
NODE_ENV=development

MONGODB_URI=YOUR_MONGODB_URI_HERE

JWT_SECRET=CHANGE_THIS_TO_A_SECURE_VALUE
JWT_EXPIRE=7d

CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=YOUR_EMAIL_HERE
EMAIL_PASS=YOUR_EMAIL_PASSWORD_HERE

CORS_ORIGINS=http://localhost:3001

# ─── NLP / AI Service (Optional — planned feature, not yet implemented) ────────
# Set NLP_ENABLED=true when the Python NLP microservice is running
NLP_ENABLED=false
NLP_SERVICE_URL=http://localhost:5000
NLP_SERVICE_TIMEOUT_MS=5000    # Timeout for NLP HTTP calls in milliseconds